{
  "name": "@proof-computer/proof-cli-blackbox",
  "version": "0.1.0",
  "description": "Blackbox plugin for the PROOF command line interface.",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "oclif.manifest.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && oclif manifest",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "prepare": "pnpm run build && node scripts/verify-package.mjs",
    "pack:dry-run": "npm pack --dry-run --json --ignore-scripts --cache .tmp/npm-cache",
    "smoke:proof-plugin": "node scripts/smoke-proof-plugin.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proof-computer/proof-cli-blackbox.git"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@oclif/core": "^4.11.3",
    "@polkadot/keyring": "^14.0.3",
    "@polkadot/util": "^14.0.3",
    "@polkadot/util-crypto": "^14.0.3",
    "ethers": "^6.15.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "oclif": "^4.23.7",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "oclif": {
    "commands": "./dist/commands",
    "topicSeparator": " ",
    "topics": {
      "blackbox": {
        "description": "Blackbox logging commands"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "UNLICENSED"
}
